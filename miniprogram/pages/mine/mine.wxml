<view class="page">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="user-avatar">{{userInfo.nickName ? userInfo.nickName[0] : '👤'}}</view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
      <text class="user-desc">今日已使用 {{dailyCount}} 次</text>
    </view>
    <button wx:if="{{!userInfo.nickName}}" class="login-btn" catchtap="onLogin">登录</button>
  </view>

  <!-- 统计 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">总对话</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.saved}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.categories}}</text>
      <text class="stat-label">覆盖场景</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" catchtap="onFeedback">
      <text class="menu-icon">💡</text>
      <text class="menu-label">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <button class="menu-item share-btn" open-type="share">
      <text class="menu-icon">📤</text>
      <text class="menu-label">分享给朋友</text>
      <text class="menu-arrow">›</text>
    </button>
    <view class="menu-item" catchtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于会说</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-card">
    <text class="tips-title">📌 使用提示</text>
    <text class="tips-text">• AI 生成的话术仅供参考，请结合实际情况使用</text>
    <text class="tips-text">• 涉及重大利益关系的沟通，建议咨询专业人士</text>
    <text class="tips-text">• 每日免费调用次数有限，超出可等待次日重置</text>
  </view>
</view>
