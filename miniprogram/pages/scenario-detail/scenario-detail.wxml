<view class="page">
  <!-- 场景信息 -->
  <view class="scenario-info">
    <view class="scenario-header">
      <text class="scenario-category tag" wx:if="{{scenario.category}}">{{categoryNames[scenario.category] || scenario.category}}</text>
      <text class="scenario-title">{{scenario.title || '场景详情'}}</text>
    </view>
    <text class="scenario-desc" wx:if="{{scenario.description}}">{{scenario.description}}</text>
    <text class="scenario-desc" wx:else>加载中...</text>
  </view>

  <!-- 填写表单 -->
  <view wx:if="{{!showResult}}" class="form-section">
    <view class="form-title">填写以下信息</view>

    <view class="form-group" wx:for="{{formFields}}" wx:for-item="field" wx:key="index">
      <text class="form-label">{{field.label}}</text>
      <input
        class="form-input"
        placeholder="{{field.placeholder}}"
        value="{{field.value}}"
        bindinput="onFieldInput"
        data-index="{{index}}"
      />
    </view>

    <!-- 补充背景 -->
    <view class="form-group">
      <text class="form-label">补充背景（可选）</text>
      <textarea
        class="form-textarea"
        placeholder="补充对方的性格、你们之间的关系等额外信息，让AI更精准"
        value="{{extraContext}}"
        bindinput="onExtraContextInput"
      />
    </view>

    <button class="submit-btn" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">
      生成话术方案
    </button>
  </view>

  <!-- 结果展示 -->
  <view wx:else class="result-section">
    <!-- 思考过程（默认折叠，包含局势分析+策略建议） -->
    <view wx:if="{{analysisParts.length || strategyParts.length}}" class="thinking-section">
      <view class="thinking-header" catchtap="toggleThinking">
        <text class="thinking-icon">💭</text>
        <text class="thinking-title">思考过程</text>
        <text class="thinking-arrow">{{thinkingExpanded ? '▲ 收起' : '▼ 展开'}}</text>
      </view>
      <view class="thinking-body {{thinkingExpanded ? 'thinking-expanded' : 'thinking-collapsed'}}">
        <!-- 局势分析 -->
        <view class="result-block" wx:if="{{analysisParts.length}}">
          <view class="block-header">
            <text class="block-icon">📊</text>
            <text class="block-title">局势分析</text>
          </view>
          <view class="block-content thinking-text">
            <text wx:for="{{analysisParts}}" wx:key="index">{{item}}</text>
          </view>
        </view>
        <!-- 策略建议 -->
        <view class="result-block" wx:if="{{strategyParts.length}}">
          <view class="block-header">
            <text class="block-icon">🎯</text>
            <text class="block-title">策略建议</text>
          </view>
          <view class="strategy-list">
            <view class="strategy-item" wx:for="{{strategyParts}}" wx:for-item="strategy" wx:key="index">
              <text class="strategy-num">{{index + 1}}</text>
              <text class="strategy-text thinking-text">{{strategy}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 话术方案卡片 -->
    <view class="result-block script-block">
      <view class="block-header">
        <text class="block-icon">💬</text>
        <text class="block-title">话术方案</text>
      </view>

      <!-- 多方案卡片 -->
      <view wx:if="{{scriptVariants.length > 0}}" class="variant-list">
        <view class="variant-card" wx:for="{{scriptVariants}}" wx:for-item="variant" wx:key="index">
          <view class="variant-num-wrap">
            <text class="variant-num">方案 {{index + 1}}</text>
            <text class="variant-title">{{variant.title}}</text>
          </view>
          <text class="variant-content">{{variant.content}}</text>
          <view class="variant-actions">
            <view class="v-action v-action-copy" catchtap="onCopyScript" data-index="{{index}}">
              复制
            </view>
            <view class="v-action v-action-edit" catchtap="onShowAdjust" data-index="{{index}}">
              调整
            </view>
          </view>
        </view>
      </view>

      <!-- 兼容旧格式（无多方案时） -->
      <view wx:else class="script-list">
        <view class="script-item" wx:for="{{scriptParts}}" wx:for-item="script" wx:key="index">
          <text class="script-label">话术 {{index + 1}}</text>
          <text class="script-text">{{script}}</text>
        </view>
      </view>
    </view>

    <!-- 重新生成区域 -->
    <view class="regen-section">
      <view wx:if="{{!showRegenInput}}" class="regen-trigger" catchtap="onToggleRegenInput">
        <text class="regen-trigger-icon">🔄</text>
        <text class="regen-trigger-text">对结果不满意？输入调整方向重新生成</text>
      </view>
      <view wx:else class="regen-input-wrap">
        <textarea class="regen-input" placeholder="输入你想调整的方向，如：更委婉一些、更正式、加入法律条款等（可不填直接重新生成）" value="{{regenInput}}" bindinput="onRegenInput" />
        <view class="regen-btns">
          <view class="regen-btn regen-btn-cancel" catchtap="onToggleRegenInput">取消</view>
          <view class="regen-btn regen-btn-go" catchtap="onRegenerate">重新生成</view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <button class="action-btn copy-btn" bindtap="onCopy">
        📋 复制全部
      </button>
      <button class="action-btn save-btn {{isSaved ? 'saved' : ''}}" bindtap="onSave">
        {{isSaved ? '⭐' : '☆'}} 收藏
      </button>
      <button class="action-btn retry-btn" bindtap="onRetry">
        🔄 返回修改
      </button>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{submitting}}" class="loading-overlay">
    <view class="loading-card">
      <view class="loading-spinner"></view>
      <text class="loading-text">AI 正在思考...</text>
      <text class="loading-desc">分析您的场景，生成最佳沟通方案</text>
    </view>
  </view>

  <!-- 调整弹窗 -->
  <view wx:if="{{showAdjustModal}}" class="modal-overlay">
    <view class="modal-card">
      <view class="modal-header">
        <text class="modal-title">调整话术方案 {{adjustIndex + 1}}</text>
        <text class="modal-close" catchtap="onCloseAdjust">✕</text>
      </view>
      <view class="modal-body">
        <text class="modal-label">请输入调整方向：</text>
        <textarea class="modal-input" placeholder="例如：更委婉一些、语气更强硬、加入法律依据、更口语化..." value="{{adjustInput}}" bindinput="onAdjustInput" />
      </view>
      <view class="modal-footer">
        <view class="modal-btn modal-btn-cancel" catchtap="onCloseAdjust">取消</view>
        <view class="modal-btn modal-btn-go {{adjustLoading ? 'disabled' : ''}}" catchtap="onSubmitAdjust">
          {{adjustLoading ? '调整中...' : '确认调整'}}
        </view>
      </view>
    </view>
  </view>
</view>
