.page { min-height: 100vh; background: var(--bg-primary); }

/* Tab 切换 */
.tabs {
  display: flex; margin: var(--space-md);
  background: #F2F2F7; border-radius: 16rpx; padding: 6rpx;
}
.tab {
  flex: 1; text-align: center; padding: 18rpx 0;
  font-size: 26rpx; border-radius: 12rpx;
  color: var(--text-secondary); font-weight: 500;
  transition: all 0.3s ease;
}
.tab.active {
  background: var(--bg-secondary); color: var(--text-primary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  font-weight: 600;
}

/* 卡片列表 */
.card-list { display: flex; flex-direction: column; gap: 20rpx; padding: 0 var(--space-md) 40rpx; }

.card-item {
  background: var(--bg-secondary); border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
  transition: all 0.2s ease;
}
.card-item:active { transform: scale(0.98); }

.card-header {
  display: flex; justify-content: space-between; align-items: flex-start;
  padding: 24rpx 24rpx 0;
}
.card-title {
  font-size: 28rpx; font-weight: 600; flex: 1;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  margin-right: 16rpx; color: var(--text-primary);
}
.card-time { font-size: 22rpx; color: var(--text-quaternary); flex-shrink: 0; margin-top: 4rpx; }

.card-category {
  display: inline-block; margin: 14rpx 24rpx 0;
  padding: 4rpx 18rpx; background: var(--color-primary-light);
  border-radius: var(--radius-full); font-size: 22rpx;
  color: var(--color-primary); font-weight: 500;
}

.card-preview {
  display: block; padding: 14rpx 24rpx 24rpx;
  font-size: 26rpx; color: var(--text-tertiary);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.card-footer {
  display: flex; justify-content: flex-end; gap: 12rpx;
  padding: 0 24rpx 20rpx;
}
.card-action {
  font-size: 24rpx; color: var(--text-tertiary);
  padding: 8rpx 24rpx; border-radius: var(--radius-full);
  border: 2rpx solid var(--border-secondary);
  transition: all 0.2s ease;
}
.card-action:active { background: var(--color-error); color: white; border-color: var(--color-error); }

.loading-area { padding: var(--space-md); }

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 160rpx 40rpx; text-align: center;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; opacity: 0.3; }
.empty-text { font-size: 30rpx; color: var(--text-tertiary); font-weight: 500; }
.empty-desc { font-size: 26rpx; color: var(--text-quaternary); margin-top: 10rpx; }
