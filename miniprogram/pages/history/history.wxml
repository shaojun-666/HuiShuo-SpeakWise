<view class="page">
  <!-- Tab 切换 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'history' ? 'active' : ''}}" catchtap="switchTab" data-tab="history">
      <text>对话记录</text>
    </view>
    <view class="tab {{activeTab === 'saved' ? 'active' : ''}}" catchtap="switchTab" data-tab="saved">
      <text>收藏话术</text>
    </view>
  </view>

  <!-- 对话记录 -->
  <view wx:if="{{activeTab === 'history'}}">
    <view wx:if="{{loading}}" class="loading-area">
      <view class="skeleton" style="height:180rpx; margin-bottom:20rpx;"></view>
      <view class="skeleton" style="height:180rpx; margin-bottom:20rpx;"></view>
    </view>

    <view wx:elif="{{historyList.length === 0}}" class="empty-state">
      <text class="empty-icon">💬</text>
      <text class="empty-text">暂无对话记录</text>
      <text class="empty-desc">去首页选择一个场景开始吧</text>
    </view>

    <view wx:else class="card-list">
      <view
        class="card-item"
        wx:for="{{historyList}}"
        wx:key="_id"
        catchtap="onHistoryTap"
        data-id="{{item._id}}"
        data-content="{{item.aiResponse}}"
        data-title="{{item.userInput}}"
      >
        <view class="card-header">
          <text class="card-title">{{item.userInput}}</text>
          <text class="card-time">{{formatTime(item.createdAt)}}</text>
        </view>
        <text class="card-category" wx:if="{{item.category}}">{{categoryNames[item.category] || item.category}}</text>
        <text class="card-preview">{{item.aiResponse}}</text>
      </view>
    </view>
  </view>

  <!-- 收藏话术 -->
  <view wx:else>
    <view wx:if="{{loading}}" class="loading-area">
      <view class="skeleton" style="height:180rpx; margin-bottom:20rpx;"></view>
    </view>

    <view wx:elif="{{savedList.length === 0}}" class="empty-state">
      <text class="empty-icon">⭐</text>
      <text class="empty-text">暂无收藏</text>
      <text class="empty-desc">在对话结果中点击收藏即可保存</text>
    </view>

    <view wx:else class="card-list">
      <view class="card-item" wx:for="{{savedList}}" wx:key="_id" catchtap="onSavedTap" data-item="{{item}}">
        <view class="card-header">
          <text class="card-title">{{item.content.title || '自由对话'}}</text>
          <text class="card-time">{{formatTime(item.createdAt)}}</text>
        </view>
        <text class="card-category" wx:if="{{item.content.category}}">{{categoryNames[item.content.category] || item.content.category}}</text>
        <text class="card-preview">{{item.content.content || item.content}}</text>
        <view class="card-footer">
          <view class="card-action" catchtap="onDeleteSaved" data-id="{{item._id}}">删除</view>
        </view>
      </view>
    </view>
  </view>
</view>
