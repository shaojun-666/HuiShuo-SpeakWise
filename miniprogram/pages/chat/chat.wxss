.page {
  display: flex; flex-direction: column; height: 100vh;
  background: linear-gradient(180deg, #F0F4FF 0%, #F5F5F7 30%);
}

/* 消息列表 */
.message-list {
  flex: 1; padding: 24rpx 20rpx 16rpx; overflow-y: auto;
}

/* 欢迎页 */
.welcome {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 32rpx 40rpx;
  animation: fadeUp 0.5s ease;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.welcome-icon {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, #2B7FFF, #6C5CE7);
  display: flex; align-items: center; justify-content: center;
  font-size: 52rpx; margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(43, 127, 255, 0.25);
}
.welcome-title { font-size: 36rpx; font-weight: 700; color: #1D1D1F; }
.welcome-desc {
  font-size: 26rpx; color: var(--text-tertiary);
  text-align: center; margin-top: 12rpx; line-height: 1.7;
  max-width: 560rpx;
}

.suggestion-chips {
  display: flex; flex-wrap: wrap; justify-content: center;
  gap: 16rpx; margin-top: 40rpx; width: 100%;
}
.chip {
  padding: 18rpx 32rpx; background: var(--bg-secondary);
  border-radius: var(--radius-full); font-size: 24rpx;
  color: var(--text-secondary); border: 2rpx solid var(--border-secondary);
  transition: all 0.2s ease; box-shadow: var(--shadow-sm);
}
.chip:active {
  background: var(--color-primary); border-color: var(--color-primary);
  color: var(--text-white); transform: scale(0.96);
}

/* 消息气泡 */
.message {
  display: flex; gap: 16rpx; margin-bottom: 28rpx;
  animation: msgIn 0.3s ease;
}
@keyframes msgIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.user-msg { flex-direction: row-reverse; }
.msg-avatar {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.user-msg .msg-avatar {
  background: linear-gradient(135deg, #2B7FFF, #5B9AFF);
}
.ai-msg .msg-avatar {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
}
.msg-content { max-width: 78%; }
.msg-bubble {
  padding: 22rpx 28rpx; border-radius: 24rpx;
  font-size: 28rpx; line-height: 1.7;
  position: relative;
}
.user-msg .msg-bubble {
  background: linear-gradient(135deg, #2B7FFF, #3D8CFF);
  color: var(--text-white);
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(43, 127, 255, 0.25);
}
.ai-msg .msg-bubble {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.msg-text { display: block; white-space: pre-wrap; }
.msg-actions {
  display: flex; gap: 24rpx;
  margin-top: 12rpx; padding-left: 8rpx;
}
.msg-action {
  font-size: 22rpx; color: var(--text-tertiary);
  padding: 4rpx 0;
}

/* 结构化回复：思考过程 */
.chat-think {
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border-secondary);
  padding-bottom: 14rpx;
}
.chat-think-header {
  display: flex; align-items: center; gap: 8rpx;
  padding: 6rpx 0;
}
.chat-think-header:active { opacity: 0.6; }
.chat-think-text { font-size: 22rpx; color: #8E8E93; flex: 1; }
.chat-think-arrow { font-size: 20rpx; color: #C7C7CC; }
.chat-think-body { overflow: hidden; }
.chat-think-fold { display: none; }
.chat-think-open { display: block; margin-top: 8rpx; }
.chat-think-content {
  display: block; font-size: 22rpx; color: #8E8E93;
  line-height: 1.6; white-space: pre-wrap;
}
.chat-script {
  display: block; font-size: 28rpx; line-height: 1.7;
  white-space: pre-wrap; color: var(--text-primary);
}

/* 输入区 */
.input-area {
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0,0,0,0.05);
}
.input-wrapper {
  display: flex; align-items: center; gap: 12rpx;
  background: #F2F2F7;
  border-radius: 40rpx;
  padding: 4rpx 4rpx 4rpx 28rpx;
  transition: all 0.2s ease;
}
.input-wrapper:focus-within {
  background: #FFFFFF;
  box-shadow: 0 0 0 2rpx rgba(43, 127, 255, 0.15);
}
.text-input {
  flex: 1; font-size: 28rpx; height: 68rpx;
  color: var(--text-primary);
}
.send-btn {
  height: 68rpx; min-width: 120rpx; padding: 0 28rpx;
  background: #E5E5EA; color: #FFFFFF;
  border-radius: 40rpx; font-size: 26rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s ease;
  border: none;
}
.send-btn.send-active {
  background: linear-gradient(135deg, #34C759, #30D158);
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.35);
}
.send-btn.send-active:active {
  transform: scale(0.94);
  opacity: 0.9;
}
.send-btn[disabled] { opacity: 0.6; }
