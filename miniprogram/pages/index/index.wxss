.page { padding: 0 0 120rpx; }
.header {
  padding: 40rpx var(--space-md) 16rpx;
  background: linear-gradient(180deg, #F0F4FF 0%, transparent 100%);
}
.logo-area { display: flex; align-items: baseline; gap: 12rpx; }
.logo-text {
  font-size: 52rpx; font-weight: 700;
  background: linear-gradient(135deg, #2B7FFF, #6C5CE7);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.logo-subtitle { font-size: 26rpx; color: var(--text-tertiary); }

/* 搜索框 */
.search-box {
  margin: 12rpx var(--space-md);
  padding: 22rpx 28rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 2rpx solid var(--border-secondary);
  transition: all 0.2s ease;
}
.search-box:active {
  border-color: var(--color-primary);
  box-shadow: 0 2rpx 16rpx rgba(43, 127, 255, 0.12);
}
.search-icon { font-size: 32rpx; }
.search-placeholder { color: var(--text-tertiary); font-size: 28rpx; }

/* 分类导航 */
.categories {
  display: flex;
  gap: 12rpx;
  padding: 12rpx var(--space-md);
  overflow-x: auto;
  white-space: nowrap;
  scrollbar-width: none;
}
.categories::-webkit-scrollbar { display: none; }
.category-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  flex-shrink: 0;
  border: 2rpx solid var(--border-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  transition: all 0.2s ease;
}
.category-item:active { transform: scale(0.95); }
.category-item.active {
  background: linear-gradient(135deg, #2B7FFF, #5B9AFF);
  color: var(--text-white);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(43, 127, 255, 0.25);
}
.category-icon { font-size: 28rpx; }
.category-name { font-weight: 500; }

/* 场景列表 */
.section { margin: 24rpx var(--space-md); }
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title { font-size: 34rpx; font-weight: 700; color: var(--text-primary); }
.section-count { font-size: 24rpx; color: var(--text-tertiary); }

.scenario-list { display: flex; flex-direction: column; gap: 16rpx; }
.scenario-item {
  background: var(--bg-secondary);
  border-radius: 20rpx;
  padding: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}
.scenario-item:active {
  transform: scale(0.98);
  border-color: var(--color-primary-light);
  box-shadow: 0 4rpx 20rpx rgba(43, 127, 255, 0.1);
}
.scenario-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.scenario-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.hot-badge {
  font-size: 22rpx; color: #FF3B30;
  background: linear-gradient(135deg, #FFF0F0, #FFE8E8);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}
.scenario-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.scenario-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}
.scenario-count { font-size: 22rpx; color: var(--text-quaternary); }

.loading-area { padding: var(--space-md) 0; }

/* 自由对话入口 */
.free-chat-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 32rpx var(--space-md);
  padding: 28rpx;
  background: linear-gradient(135deg, #E8F0FF, #F0F5FF);
  border-radius: 20rpx;
  border: 2rpx solid rgba(43, 127, 255, 0.2);
  transition: all 0.2s ease;
}
.free-chat-entry:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(43, 127, 255, 0.15);
}
.free-chat-icon {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: linear-gradient(135deg, #2B7FFF, #6C5CE7);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
}
.free-chat-text { flex: 1; }
.free-chat-title { font-size: 30rpx; font-weight: 600; color: var(--color-primary); display: block; }
.free-chat-desc { font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; display: block; }
.free-chat-arrow { font-size: 40rpx; color: var(--color-primary); }
