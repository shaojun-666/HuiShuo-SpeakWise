/* 主题色 */
:root {
  --color-primary: #2B7FFF;
  --color-primary-light: #E8F0FF;
  --color-primary-dark: #1A5FD4;
  --color-success: #34C759;
  --color-warning: #FF9500;
  --color-error: #FF3B30;
  --color-info: #5AC8FA;

  /* 文字 */
  --text-primary: #1D1D1F;
  --text-secondary: #6E6E73;
  --text-tertiary: #86868B;
  --text-quaternary: #C7C7CC;
  --text-white: #FFFFFF;

  /* 背景 */
  --bg-primary: #EFEFF2;
  --bg-secondary: #FFFFFF;
  --bg-tertiary: #E8E8ED;
  --bg-hover: #F0F0F5;

  /* 边框 */
  --border-primary: #D2D2D7;
  --border-secondary: #E5E5EA;

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}
