.scenario-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  box-shadow: var(--shadow-sm);
  margin-bottom: 16rpx;
}
.card-top { display: flex; justify-content: space-between; align-items: center; }
.card-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.hot-badge { font-size: 22rpx; color: var(--color-error); background: #FFF0F0; padding: 4rpx 14rpx; border-radius: var(--radius-full); }
.card-desc { font-size: 26rpx; color: var(--text-secondary); margin-top: 12rpx; display: block; }
.card-footer { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.card-category {}
.card-count { font-size: 22rpx; color: var(--text-quaternary); }
