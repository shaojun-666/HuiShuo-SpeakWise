.result-card { padding: var(--space-md); }
.section { margin-bottom: 24rpx; }
.section-header { display: flex; align-items: center; gap: 10rpx; margin-bottom: 12rpx; }
.section-icon { font-size: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; }
.section-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.8; display: block; white-space: pre-wrap; }
.script-section { background: var(--color-primary-light); margin: 0 -24rpx; padding: 24rpx; border-radius: var(--radius-md); }
.script-text { color: var(--text-primary); }
.card-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.action { font-size: 24rpx; color: var(--color-primary); padding: 12rpx 20rpx; background: var(--color-primary-light); border-radius: var(--radius-sm); }
